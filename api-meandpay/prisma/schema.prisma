model target_kinerja_teams {
  id                    BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  target_kinerja_id     BigInt?          @db.UnsignedBigInt
  user_id               BigInt?          @db.UnsignedBigInt
  jabatan_id            BigInt?          @db.UnsignedBigInt
  target_pribadi        BigInt?
  jumlah_persen_pribadi BigInt?
  bonus_pribadi         BigInt?
  judul                 String?
  jumlah                BigInt?
  capai                 Float?
  nilai                 String?
  bonus_p               BigInt?
  bonus_t               BigInt?
  bonus_j               BigInt?
  keterangan            String?          @db.Text
  created_at            DateTime?        @db.Timestamp(0)
  updated_at            DateTime?        @db.Timestamp(0)
  jabatans              jabatans?        @relation(fields: [jabatan_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "target_kinerja_teams_jabatan_id_foreign")
  target_kinerjas       target_kinerjas? @relation(fields: [target_kinerja_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "target_kinerja_teams_target_kinerja_id_foreign")
  users                 users?           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "target_kinerja_teams_user_id_foreign")

